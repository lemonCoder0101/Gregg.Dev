# ─────────────────────────────────────────────
# DEPENDENCIES
# ─────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─────────────────────────────────────────────
# NEXT.JS BUILD OUTPUT
# ─────────────────────────────────────────────
/.next/
/out/
/build

# ─────────────────────────────────────────────
# TESTING & COVERAGE
# ─────────────────────────────────────────────
/coverage

# ─────────────────────────────────────────────
# ENVIRONMENT & SECRETS
# ─────────────────────────────────────────────
.env
.env.*
!.env.example

# ─────────────────────────────────────────────
# LOGS
# ─────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ─────────────────────────────────────────────
# OS / EDITOR ARTIFACTS
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─────────────────────────────────────────────
# TYPESCRIPT
# ─────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─────────────────────────────────────────────
# DEPLOYMENT
# ─────────────────────────────────────────────
.vercel

# ─────────────────────────────────────────────
# MARKDOWN — ignore all except README.md
# ─────────────────────────────────────────────
*.md
!README.md

# ─────────────────────────────────────────────
# MISC NEXT.JS SCAFFOLDED ASSETS (unused)
# ─────────────────────────────────────────────
/public/file.svg
/public/globe.svg
/public/next.svg
/public/vercel.svg
/public/window.svg
